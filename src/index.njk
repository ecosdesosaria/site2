    <!-- Script para animações e funcionalidades -->
    <script>
        // Função para atualizar o status do servidor
        async function atualizarStatus() {
            const statusEl = document.querySelector(".server-status");
            const countEl = document.getElementById("count");
            const list = document.getElementById("players");
            const accountsEl = document.getElementById("accounts");

            try {
                const res = await fetch("/api/players", { cache: "no-store" });
                if (!res.ok) throw new Error("HTTP " + res.status);
                const data = await res.json();

                // Server status (online/offline)
                if (data.online) {
                    statusEl.innerHTML = '<i class="bi bi-check-circle-fill me-1"></i>Online';
                    statusEl.classList.remove("text-danger", "border-danger");
                    statusEl.classList.add("text-success", "border-success");
                    statusEl.style.color = "";
                } else {
                    statusEl.innerHTML = '<i class="bi bi-x-circle-fill me-1"></i>Offline';
                    statusEl.classList.remove("text-success", "border-success");
                    statusEl.classList.add("text-danger", "border-danger");
                    statusEl.style.color = "";
                }

                // Player count & accounts
                countEl.textContent = " " + data.count;
                if (accountsEl) accountsEl.textContent = " " + data.accounts;

                // Player list
                list.innerHTML = "";
                if (data.count === 0) {
                    list.innerHTML = "<li class='text-muted'><i class='bi bi-person-x me-2'></i>Nenhum jogador online</li>";
                } else {
                    data.players.forEach(name => {
                        const li = document.createElement("li");
                        li.innerHTML = `<i class="bi bi-person-fill me-2 text-success"></i>${escapeHtml(name)}`;
                        list.appendChild(li);
                    });
                }

            } catch (e) {
                statusEl.innerHTML = '<i class="bi bi-exclamation-triangle-fill me-1"></i>Offline';
                statusEl.classList.remove("text-success", "border-success");
                statusEl.classList.add("text-danger", "border-danger");
                countEl.textContent = "0";
                if (accountsEl) accountsEl.textContent = "0";
                list.innerHTML = "<li class='text-muted'><i class='bi bi-wifi-off me-2'></i>Erro ao conectar</li>";
                console.error("atualizarStatus error:", e);
            }
        }

        // função simples para escapar HTML (nome do player)
        function escapeHtml(text) {
            return text.replace(/[&<>"'`=\/]/g, function (s) {
                return ({
                    '&': '&amp;',
                    '<': '&lt;',
                    '>': '&gt;',
                    '"': '&quot;',
                    "'": '&#39;',
                    '/': '&#x2F;',
                    '`': '&#x60;',
                    '=': '&#x3D;'
                })[s];
            });
        }

        // inicializa
        atualizarStatus();
        setInterval(atualizarStatus, 50000);

        // Suavizar rolagem para âncoras
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                }
            });
        });
        
        // Adicionar classe ativa ao item de menu quando a seção estiver visível
        window.addEventListener('scroll', function() {
            const sections = document.querySelectorAll('section');
            const navLinks = document.querySelectorAll('.uo-nav .nav-link');
            
            let current = '';
            sections.forEach(section => {
                const sectionTop = section.offsetTop;
                const sectionHeight = section.clientHeight;
                if (scrollY >= (sectionTop - 100)) {
                    current = section.getAttribute('id');
                }
            });
            
            navLinks.forEach(link => {
                link.classList.remove('active');
                if (link.getAttribute('href') === `#${current}`) {
                    link.classList.add('active');
                }
            });
        });
    </script>

